        "Modified Date": "2025-05-11T10:27:54.636Z",
        "value": "\u0645\u0646\u0635\u0629 \u0645\u062a\u0643\u0627\u0645\u0644\u0629 \u062a\u062a\u064a\u062d \u0644\u0643 \u0625\u062f\u0627\u0631\u0629 \u0627\u0644\u0639\u0642\u0648\u062f \u0648\u0627\u0644\u0627\u062a\u0641\u0627\u0642\u064a\u0627\u062a \u0628\u0643\u0644 \u0633\u0647\u0648\u0644\u0629 \u0648\u0627\u062d\u062a\u0631\u0627\u0641\u064a\u0629. \u0635\u0645\u0651\u0645\u060c \u0631\u0627\u062c\u0639\u060c \u0648\u0648\u0642\u0651\u0639 \u0645\u0633\u062a\u0646\u062f\u0627\u062a\u0643 \u0641\u064a \u0645\u0643\u0627\u0646 \u0648\u0627\u062d\u062f\u060c \u0628\u062f\u0648\u0646 \u0627\u0644\u062d\u0627\u062c\u0629 \u0644\u0644\u0637\u0628\u0627\u0639\u0629 \u0623\u0648 \u0627\u0644\u0628\u0631\u064a\u062f. \u0648\u0641\u0631 \u0648\u0642\u062a\u0643\u060c \u0648\u0631\u0643\u0651\u0632 \u0639\u0644\u0649 \u0646\u0645\u0648 \u0623\u0639\u0645\u0627\u0644\u0643 \u0628\u064a\u0646\u0645\u0627 \u0646\u0647\u062a\u0645 \u0646\u062d\u0646 \u0628\u0627\u0644\u062a\u0641\u0627\u0635\u064a\u0644 \u0627\u0644\u0642\u0627\u0646\u0648\u0646\u064a\u0629. \u0648\u0627\u062c\u0647\u0629 \u0633\u0647\u0644\u0629\u060c \u062a\u062c\u0631\u0628\u0629 \u0633\u0644\u0633\u0629\u060c \u0648\u062e\u062f\u0645\u0627\u062a \u0645\u0635\u0645\u0645\u0629 \u0644\u062a\u0646\u0627\u0633\u0628 \u0627\u062d\u062a\u064a\u0627\u062c\u0643\u060c \u0633\u0648\u0627\u0621 \u0643\u0646\u062a \u0641\u0631\u062f\u060c \u0634\u0631\u0643\u0629\u060c \u0623\u0648 \u062c\u0647\u0629  .",
